@model List<SmartLostAndFound.Models.Item>

@{
    ViewData["Title"] = "My Items";
}

<h4 class="mb-3">My Items</h4>

@if (!Model.Any())
{
    <div class="alert alert-info py-2">
        You have not added any items yet.
    </div>
}
else
{
    <table class="table table-hover align-middle table-bordered">
        <thead>
            <tr class="text-muted">
                <th>Title</th>
                <th>Category</th>
                <th>Color</th>
                <th>Location</th>
                <th>Date</th>
                <th>Status</th>
                <th class="text">Match</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Title</td>
                    <td>@item.Category</td>
                    <td>@item.Color</td>
                    <td>@item.Location</td>
                    <td>@item.Date.ToString("dd-MM-yyyy")</td>
                    <td>
                        @if (item.IsLost)
                        {
                            <span class="badge-lost">Lost</span>
                        }
                        else
                        {
                            <span class="badge-found">Found</span>
                        }
                    </td>
                    <td class="text">
                        <a asp-controller="Items"
                           asp-action="Matches"
                           asp-route-id="@item.Id"
                           class="text-decoration-none text-secondary">
                            View matches
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
