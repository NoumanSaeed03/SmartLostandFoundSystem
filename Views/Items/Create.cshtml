@model SmartLostAndFound.Models.Item

@{
    ViewData["Title"] = "Add Item";
}

<h2>Add Item</h2>

<form asp-action="Create" method="post">

    <div class="form-group mb-3">
        <label asp-for="Title"></label>
        <input asp-for="Title" class="form-control" />
        <span asp-validation-for="Title" class="text-danger"></span>
    </div>

    <div class="form-group mb-3">
        <label asp-for="Category"></label>
        <select asp-for="Category" class="form-control">
            <option value="">-- Select Category --</option>
            <option value="Personal Belongings">Personal Belongings</option>
            <option value="Electronics">Electronics</option>
            <option value="Accessories">Accessories</option>
            <option value="Bags">Bags & Containers</option>
            <option value="Clothing">Clothing</option>
            <option value="Academic Items">Academic Items</option>
            <option value="Cards">Cards & Important Items</option>
            <option value="Sports">Sports & Fitness</option>
            <option value="Toys">Toys & Kids Items</option>
        </select>
        <span asp-validation-for="Category" class="text-danger"></span>
    </div>

    <div class="form-group mb-3">
        <label asp-for="Color"></label>
        <input asp-for="Color" class="form-control" />
    </div>

    <div class="form-group mb-3">
        <label asp-for="Location"></label>
        <input asp-for="Location" class="form-control" />
        <span asp-validation-for="Location" class="text-danger"></span>
    </div>

    <div class="form-group mb-3">
        <label asp-for="Date"></label>
        <input asp-for="Date" type="date" class="form-control" />
        <span asp-validation-for="Date" class="text-danger"></span>
    </div>

    <div class="form-group mb-3">
        <label asp-for="IsLost"></label>
        <select asp-for="IsLost" class="form-control">
            <option value="true">Lost</option>
            <option value="false">Found</option>
        </select>
    </div>


    <div class="form-group mb-3">
        <label asp-for="Contact"></label>
        <input asp-for="Contact" class="form-control" placeholder="Enter phone or email" />
        <span asp-validation-for="Contact" class="text-danger"></span>
    </div>

    <div class="form-group mb-3">
        <label asp-for="Address"></label>
        <input asp-for="Address" class="form-control" placeholder="Enter address details" />
        <span asp-validation-for="Address" class="text-danger"></span>
    </div>


    <button type="submit" class="btn btn-primary">Save</button>
    <a asp-action="MyItem" class="btn btn-secondary ms-2">Back</a>

</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}