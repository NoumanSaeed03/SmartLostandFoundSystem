@using Microsoft.AspNetCore.Identity
@inject UserManager<SmartLostandFoundSystem.Models.ApplicationUser> UserManager

@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString();
    string firstName = "";

    if (User.Identity.IsAuthenticated)
    {
        // Try to get full name from claim
        var fullName = User.Claims.FirstOrDefault(c => c.Type == "FullName")?.Value;
        if (!string.IsNullOrEmpty(fullName))
        {
            firstName = fullName.Split(' ')[0]; // First name only
        }
        else
        {
            firstName = User.Identity.Name.Split('@')[0]; // fallback to email username
        }
    }
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SmartLostandFoundSystem</title>

    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- Custom CSS -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/SmartLostandFoundSystem.styles.css" asp-append-version="true" />
</head>

<body>
    <header>
        <nav class="navbar navbar-expand-lg">
            <div class="container-fluid">
                <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                    Smart Lost & Found
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse"
                        data-bs-target="#navbarNav">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse justify-content-center" id="navbarNav">
                    <ul class="navbar-nav align-items-center">

                        @* =================== Greeting first =================== *@
                        @if (User.Identity.IsAuthenticated)
                        {
                            <li class="nav-item">
                                <span class="navbar-text me-3">
                                    Hello, <strong>@firstName</strong>
                                </span>
                            </li>
                        }

                        @* =================== Home =================== *@
                        <li class="nav-item">
                            <a class="nav-link @(currentController=="Home" && currentAction=="Index" ? "active" : "")"
                               asp-controller="Home" asp-action="Index">Home</a>
                        </li>

                        @* =================== Guest links =================== *@
                        @if (!User.Identity.IsAuthenticated)
                        {
                            <li class="nav-item">
                                <a class="nav-link @(currentController=="Account" && currentAction=="Register" ? "active" : "")"
                                   asp-controller="Account" asp-action="Register">Register</a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link @(currentController=="Account" && currentAction=="Login" ? "active" : "")"
                                   asp-controller="Account" asp-action="Login">Login</a>
                            </li>
                        }
                        else
                        {
                            @* =================== User links =================== *@
                            @if (User.IsInRole("User"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link @(currentController=="Items" && currentAction=="MyItem" ? "active" : "")"
                                       asp-controller="Items" asp-action="MyItem">My Items</a>
                                </li>

                                <li class="nav-item">
                                    <a class="nav-link @(currentController=="Items" && currentAction=="Create" ? "active" : "")"
                                       asp-controller="Items" asp-action="Create">Add Item</a>
                                </li>
                            }

                            @* =================== Admin links =================== *@
                            @if (User.IsInRole("Admin"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link @(currentController=="Items" && currentAction=="Index" ? "active" : "")"
                                       asp-controller="Items" asp-action="Index">All Items</a>
                                </li>

                                <li class="nav-item">
                                    <a class="nav-link @(currentController=="Admin" ? "active" : "")"
                                       asp-controller="Admin" asp-action="AdminDashboard">Admin Dashboard</a>
                                </li>
                            }

                            @* =================== Privacy =================== *@
                            <li class="nav-item">
                                <a class="nav-link @(currentController=="Home" && currentAction=="Privacy" ? "active" : "")"
                                   asp-controller="Home" asp-action="Privacy">Privacy</a>
                            </li>

                            @* =================== Logout =================== *@
                            <li class="nav-item">
                                <form asp-controller="Account" asp-action="Logout" method="post">
                                    <button type="submit" class="nav-link btn btn-link logout-btn">
                                        Logout
                                    </button>
                                </form>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container mt-4">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
